{
    "name": "type-lang/dev",
    "description": "TypeLang Components Monorepo",
    "type": "library",
    "license": "MIT",
    "repositories": [
        {"type": "path", "url": "libs/*"}
    ],
    "require": {
        "php": "^8.4",
        "type-lang/parser": "^2.0",
        "type-lang/printer": "^2.0",
        "type-lang/phpdoc": "^2.0",
        "type-lang/phpdoc-standard-tags": "^2.0",
        "type-lang/phpdoc-template-tags": "^2.0",
        "type-lang/types": "^2.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95.8",
        "jetbrains/phpstorm-attributes": "^1.2",
        "phplrt/compiler": "^3.7",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.0|^13.0",
        "symfony/var-dumper": "^7.4|^8.1"
    },
    "autoload-dev": {
        "psr-4": {
             "TypeLang\\DocBlock\\Tests\\": "libs/docblock/tests",
             "TypeLang\\Parser\\Tests\\": "libs/parser/tests",
             "TypeLang\\Printer\\Tests\\": "libs/printer/tests",
             "TypeLang\\PhpDoc\\Tests\\": "libs/phpdoc/tests",
             "TypeLang\\PhpDoc\\Standard\\Tests\\": "libs/phpdoc-standard-tags/tests",
             "TypeLang\\PhpDoc\\Template\\Tests\\": "libs/phpdoc-template-tags/tests",
             "TypeLang\\Type\\Tests\\": "libs/types/tests"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.x-dev",
            "dev-main": "2.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "platform-check": true,
        "bin-compat": "full",
        "preferred-install": {
            "*": "dist"
        }
    },
    "scripts-aliases": {
        "test:unit": ["test", "phpunit", "unit"],
        "linter:check": ["linter", "stan"],
        "phpcs:check": ["phpcs", "cs", "psr", "per"]
    },
    "scripts": {
        "test:unit": "phpunit --testdox",
        "linter:check": "phpstan analyse --configuration phpstan.neon --memory-limit 256M",
        "linter:baseline": "@linter:check --generate-baseline",
        "phpcs:check": "@phpcs:fix --dry-run",
        "phpcs:fix": "php-cs-fixer fix --config=.php-cs-fixer.php --allow-risky=yes --verbose --diff"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}

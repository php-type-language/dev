<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         colors="true"
         backupGlobals="true"
         stopOnFailure="false"
         processIsolation="false"
         bootstrap="vendor/autoload.php"
         cacheDirectory="vendor/.cache.phpunit"
         backupStaticProperties="false"
>
    <testsuites>
        <testsuite name="components">
            <directory>libs/mapper/tests</directory>
            <directory>libs/mapper/libs/property-accessor/tests</directory>
            <directory>libs/parser/tests</directory>
            <directory>libs/phpdoc/tests</directory>
            <directory>libs/printer/tests</directory>
            <directory>libs/reader/tests</directory>
            <directory>libs/types/tests</directory>
        </testsuite>
    </testsuites>

    <coverage/>

    <source>
        <include>
            <directory>libs/mapper/src</directory>
            <directory>libs/mapper/libs/property-accessor/src</directory>
            <directory>libs/parser/src</directory>
            <directory>libs/phpdoc/src</directory>
            <directory>libs/printer/src</directory>
            <directory>libs/reader/src</directory>
            <directory>libs/types/src</directory>
        </include>
    </source>

    <php>
        <ini name="error_reporting" value="-1"/>
        <ini name="memory_limit" value="-1"/>
    </php>
</phpunit>
